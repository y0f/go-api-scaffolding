# Copy to .env and adjust. All variables are optional unless noted; defaults
# shown are the built-in values.

# development or production
FORGE_ENV=development

# HTTP server
FORGE_HTTP_HOST=0.0.0.0
FORGE_HTTP_PORT=8080
FORGE_HTTP_READ_HEADER_TIMEOUT=5s
FORGE_HTTP_READ_TIMEOUT=15s
FORGE_HTTP_WRITE_TIMEOUT=15s
FORGE_HTTP_IDLE_TIMEOUT=60s
FORGE_HTTP_SHUTDOWN_TIMEOUT=20s
FORGE_HTTP_DRAIN_DELAY=2s
FORGE_HTTP_CORS_ALLOWED_ORIGINS=
FORGE_HTTP_RATE_LIMIT_PER_SECOND=50
FORGE_HTTP_RATE_LIMIT_BURST=100
FORGE_HTTP_MAX_BODY_BYTES=1048576

# Admin (pprof, expvar) listener, kept off the public port
FORGE_ADMIN_ENABLED=false
FORGE_ADMIN_HOST=127.0.0.1
FORGE_ADMIN_PORT=6060
FORGE_ADMIN_TOKEN=

# Database (required)
FORGE_DB_URL=postgres://forge:forge@localhost:5432/forge?sslmode=disable
FORGE_DB_MAX_CONNS=10
FORGE_DB_MIN_CONNS=2
FORGE_DB_MAX_CONN_LIFETIME=1h
FORGE_DB_MAX_CONN_IDLE_TIME=30m
FORGE_DB_HEALTH_CHECK_PERIOD=1m
FORGE_DB_CONNECT_TIMEOUT=10s

# Telemetry. Leave OTLP_ENDPOINT empty to disable tracing; metrics stay on.
FORGE_OTEL_SERVICE_NAME=forge
FORGE_OTEL_OTLP_ENDPOINT=
FORGE_OTEL_SAMPLE_RATIO=1.0

# Auth. In production set JWKS_URL (OIDC) or PUBLIC_KEY_PATH. In development an
# ephemeral key is generated and a usable token is logged at startup.
FORGE_AUTH_JWKS_URL=
FORGE_AUTH_PUBLIC_KEY_PATH=
FORGE_AUTH_ISSUER=forge
FORGE_AUTH_AUDIENCE=forge
FORGE_AUTH_DEV_TOKEN_TTL=24h

# Logging
FORGE_LOG_LEVEL=info
FORGE_LOG_FORMAT=json
